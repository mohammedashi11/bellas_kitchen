rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    // True when the signed-in caller's own users/{uid} doc has role == 'admin'.
    // get()/exists() are privileged reads within rule evaluation, so this works
    // regardless of the users read rule below.
    function isAdmin() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Menu: public read; only admins write (menu management is a later feature).
    match /menu_items/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Users: a user reads/writes ONLY their own profile.
    match /users/{uid} {
      allow read, write: if isSignedIn() && request.auth.uid == uid;
    }

    // Orders:
    //   - a customer CREATES and READS only their own order,
    //   - an admin READS all orders and UPDATES them (status changes),
    //   - nobody deletes.
    match /orders/{id} {
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid;
      allow read: if isSignedIn()
        && (resource.data.userId == request.auth.uid || isAdmin());
      allow update: if isAdmin();
      allow delete: if false;
    }
  }
}
